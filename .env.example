# Per-Tenant Build Variables
# These are passed to Codemagic via API (or set in Codemagic UI).
# For local dev, copy this to .env and fill in.

# Unique app identifier (reverse domain). Must be unique per tenant.
# Format: app.arbordash.<company-slug>
APP_ID=app.arbordash.bullard

# Display name shown on home screen and app switcher
APP_NAME=Bullard Tree Care

# Company code — derived from tenant hostname (strip "dashboard." and ".com")
# Used to resolve branding when the app loads dashboard.arbordash.app
COMPANY_CODE=bullardtreecare

# URL to a 1024x1024 PNG icon for the app. Used by Codemagic to generate
# all required iOS and Android icon sizes during the build.
APP_ICON_URL=https://your-supabase-url.supabase.co/storage/v1/object/public/dashboard/orgId/1/images/branding/icon.png
